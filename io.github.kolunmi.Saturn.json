{
  "id" : "io.github.kolunmi.Saturn",
  "runtime" : "org.gnome.Platform",
  "runtime-version" : "49",
  "sdk" : "org.gnome.Sdk",
  "command" : "saturn",
  "finish-args" : [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--filesystem=/var/lib/flatpak",
    "--filesystem=home",
    "--talk-name=org.freedesktop.Flatpak",
    "--socket=wayland"
  ],
  "cleanup" : [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules" : [
    {
      "name" : "ecl",
      "buildsystem" : "autotools",
      "build-options" : {
        "cflags" : "-std=c99 -O2 -fasm"
      },
      "sources" : [
        {
          "type" : "git",
          "url" : "https://gitlab.com/embeddable-common-lisp/ecl.git",
          "commit" : "e4269ea51fffd742f92cb19a89f52af3cdf0d9f8",
          "tag" : "24.5.10"
        }
      ]
    },
    {
      "name" : "saturn",
      "buildsystem" : "meson",
      "sources" : [
        {
          "type" : "dir",
          "path" : "."
        }
      ]
    }
  ]
}
