{
  "id" : "io.github.kolunmi.Saturn",
  "runtime" : "org.gnome.Platform",
  "runtime-version" : "50",
  "sdk" : "org.gnome.Sdk",
  "command" : "saturn",
  "finish-args" : [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--filesystem=/var/lib/flatpak",
    "--filesystem=home",
    "--talk-name=org.freedesktop.Flatpak",
    "--socket=wayland",
    "--socket=pulseaudio"
  ],
  "cleanup" : [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules" : [
    {
      "name" : "ecl",
      "buildsystem" : "autotools",
      "build-options" : {
        "cflags" : "-std=c99 -O2 -fasm"
      },
      "sources" : [
        {
          "type" : "git",
          "url" : "https://gitlab.com/embeddable-common-lisp/ecl.git",
          "commit" : "e4269ea51fffd742f92cb19a89f52af3cdf0d9f8",
          "tag" : "24.5.10"
        }
      ]
    },
    {
      "name" : "saturn-cl-deps",
      "buildsystem" : "simple",
      "build-commands" : [
        "ecl --load build-cl-deps.lsp",
        "cp *.a /app/lib/ecl-24.5.10/"
      ],
      "sources" : [
        {
          "type" : "file",
          "path" : "build-cl-deps.lsp"
        },
        {
          "type" : "file",
          "path" : "saturn-cl-deps.asd"
        },
        {
          "type" : "git",
          "url" : "https://github.com/sionescu/bordeaux-threads.git",
          "commit" : "076fe2380abbc59b06e495dc7a35aea8eb26ba3b",
          "tag" : "v0.8.8",
          "dest" : "bordeaux-threads"
        },
        {
          "type" : "git",
          "url" : "https://github.com/sharplispers/split-sequence.git",
          "commit" : "89a10b4d697f03eb32ade3c373c4fd69800a841a",
          "dest" : "split-sequence"
        },
        {
          "type" : "git",
