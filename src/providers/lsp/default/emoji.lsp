(defvar emojis-map (make-hash-table :test #'equal))
(mapcar (lambda (x)
          (destructuring-bind (hexs names) x
            (setf (gethash hexs emojis-map) names)))
        emojis)

(gobject:define-gobject-subclass
    "SaturnEmojiResult"
    emoji-result
    (:superclass saturn:generic-result
     :export t
     :interfaces ())
    nil)
(gobject:define-gobject-subclass
    "SaturnEmojiResultListItem"
    emoji-result-list-item
    (:superclass saturn:signal-widget
     :export nil
     :interfaces ())
    nil)

(defvar list-item-ui
  "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
<interface>
  <template class=\"SaturnEmojiResultListItem\">
    <property name=\"child\">
      <object class=\"GtkBox\">
        <property name=\"orientation\">horizontal</property>
        <property name=\"spacing\">6</property>
        <child>
          <object class=\"GtkLabel\">
            <style>
              <class name=\"title-1\"/>
            </style>
            <property name=\"halign\">start</property>
            <property name=\"width-chars\">1</property>
            <binding name=\"label\">
              <lookup name=\"string\" type=\"GtkStringObject\">
                <lookup name=\"obj0\" type=\"SaturnEmojiResult\">
                  <lookup name=\"item\">SaturnEmojiResultListItem</lookup>
                </lookup>
              </lookup>
            </binding>
          </object>
        </child>
        <child>
          <object class=\"GtkLabel\">
            <style>
              <class name=\"subtitle\"/>
            </style>
